# Copy to `.env.local` for local overrides (optional). CRA loads:
#   - .env.development when running `npm start`
#   - .env.production when running `npm run build`
#
# REACT_APP_API_URL must always include the scheme: http://127.0.0.1:8000 or https://api.example.com
# Never use Railway *.internal hostnames in the browser — use the public HTTPS URL from Railway.

REACT_APP_API_URL=http://127.0.0.1:8000
REACT_APP_FRONTEND_URL=http://localhost:3000
